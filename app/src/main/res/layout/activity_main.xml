<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- 🌐 MAIN CONTAINER -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 🟪 AppBar with Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="#673AB7"
                app:title="LAXMI TRADERS"
                app:titleTextColor="@android:color/white"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- 🟩 Main Scrollable Area -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="?attr/actionBarSize"
            android:fillViewport="true"
            android:background="#F5F5F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 🧾 TODAY’S SALES -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="8dp"
                    android:elevation="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/textTodaySales"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/holo_green_dark"
                            android:gravity="center" />



                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/textTodayBillCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bills: 0"
                                android:textColor="#666666"
                                android:layout_marginEnd="20dp" />

                            <TextView
                                android:id="@+id/textAvgSale"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Avg: ₹0"
                                android:textColor="#666666" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textTodayDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="#999999"
                            android:layout_gravity="end"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 🧾 RECENT BILLS -->
                <TextView
                    android:id="@+id/textRecentBills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🧾 Recent Bills"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:elevation="3dp"
                    app:cardCornerRadius="10dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/listRecentBills"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:clipToPadding="false" />
                </androidx.cardview.widget.CardView>

                <!-- ⚙️ DATABASE ACTION BUTTONS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:elevation="3dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#FDFDFD">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:divider="?android:attr/dividerVertical"
                        android:showDividers="middle"
                        android:dividerPadding="8dp">

                        <Button
                            android:id="@+id/btnBackupDb"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="📁 Backup Database"
                            android:textAllCaps="false"
                            android:backgroundTint="#87D18A"
                            android:textColor="#FFFFFF"/>

                        <Button
                            android:id="@+id/btnRestoreDb"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="📁 Restore Database"
                            android:textAllCaps="false"
                            android:backgroundTint="#8E6262"
                            android:textColor="#FFFFFF" />

                        <Button
                            android:id="@+id/btnExportCsv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="📤 Export Billing History to Excel"
                            android:textAllCaps="false"
                            android:backgroundTint="#3F51B5"
                            android:textColor="#FFFFFF"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

        <!-- 🛒 FLOATING NEW PURCHASE BUTTON -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/newPurchaseButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="24dp"
            android:text="➕ New Purchase"
            android:icon="@drawable/ic_add_shopping_cart"
            app:backgroundTint="#B556FA"
            app:iconTint="@android:color/white"
            android:textColor="@color/white"
           />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- 🟦 Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#E8EAF6"
        app:itemTextAppearance="@style/NavDrawerText"
        app:itemIconTint="@color/nav_icon_color"
        app:itemTextColor="@color/nav_icon_color"
        app:itemBackground="@drawable/nav_item_selector"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/drawer_menu"/>
</androidx.drawerlayout.widget.DrawerLayout>